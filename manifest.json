{
  "manifest_version": 3,
  "name": "Book Donation to MARC",
  "version": "1.0.0",
  "description": "Convert Book Donation Excel templates to editable MARC21 records",
  "permissions": ["storage"],
  "action": {
    "default_title": "Open MARC Editor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
