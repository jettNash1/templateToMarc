{
  "manifest_version": 3,
  "name": "MARCLite",
  "version": "2.0.0",
  "description": "Lightweight MARC21 toolkit for import, edit, validation, cleanup, and export in your browser",
  "permissions": ["storage"],
  "action": {
    "default_title": "Open MARCLite",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
